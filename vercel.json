{
  "rewrites": [
    { "source": "/admin/sheds/:id/edit", "destination": "/admin/shed-form.html" },
    { "source": "/admin/sheds/new", "destination": "/admin/shed-form.html" },
    { "source": "/admin/buildings/:id/edit", "destination": "/admin/building-form.html" },
    { "source": "/admin/buildings/new", "destination": "/admin/building-form.html" },
    { "source": "/admin/dashboard", "destination": "/admin/dashboard.html" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/admin/logout", "destination": "/api/auth/logout" },
    { "source": "/admin/settings", "destination": "/admin/settings.html" },
    { "source": "/admin/leads", "destination": "/admin/leads.html" },
    { "source": "/admin/promo", "destination": "/admin/promo.html" },
    { "source": "/admin", "destination": "/admin/dashboard.html" },
    { "source": "/barns", "destination": "/services/metal-barns.html" },
    { "source": "/sheds", "destination": "/sheds-landing.html" },
    { "source": "/sheds-rto", "destination": "/sheds.html" },
    { "source": "/sheds4sale", "destination": "/sheds-for-sale.html" }
  ],
  "redirects": [
    { "source": "/services/metal-barns.html", "destination": "/barns", "permanent": true },
    { "source": "/sheds.html", "destination": "/sheds-rto", "permanent": true },
    { "source": "/sheds-landing.html", "destination": "/sheds", "permanent": true },
    { "source": "/sheds-for-sale.html", "destination": "/sheds4sale", "permanent": true }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
